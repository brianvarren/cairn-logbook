---
layout: base.njk
---

<article class="post">
  <header class="post-header">
    <div class="post-id">{{ page.date | postDate }}</div>
    <h1 class="post-title">{{ title }}</h1>
  </header>

  <div class="post-content">
    {{ content | safe }}
  </div>

  <a href="/" class="back-link">← Back to log</a>
</article>
